<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Back up the player name preference so it roams across devices -->
        <include domain="sharedpref" path="chick_quiz.xml"/>
        <!-- Exclude the Room database — it is rebuilt from the bundled questions.json asset -->
        <exclude domain="database" path="chick_quiz.db"/>
        <exclude domain="database" path="chick_quiz.db-wal"/>
        <exclude domain="database" path="chick_quiz.db-shm"/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="chick_quiz.xml"/>
        <exclude domain="database" path="chick_quiz.db"/>
        <exclude domain="database" path="chick_quiz.db-wal"/>
        <exclude domain="database" path="chick_quiz.db-shm"/>
    </device-transfer>
</data-extraction-rules>
